{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "frontend",
  "rewrites": [
    { "source": "/api/pelanggan", "destination": "/api/pelanggan.js" },
    { "source": "/api/pelanggan2", "destination": "/api/pelanggan2.js" }
  ],
  "functions": {
    "api/pelanggan.js": {
      "runtime": "edge",
      "maxDuration": 30
    },
    "api/pelanggan2.js": {
      "runtime": "edge",
      "maxDuration": 25
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
